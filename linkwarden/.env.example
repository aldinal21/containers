# Linkwarden Configuration
CONTAINER_NAME=linkwarden
LINKWARDEN_PORT=3002

# Database (Using your shared Postgres 16 Prod)
# Replace 100.91.82.34 with your Tailscale IP if needed
DATABASE_URL=postgresql://admin:admin@100.91.82.34:5433/linkwarden

# Auth (Generate a random string for this)
NEXTAUTH_SECRET=change_me_to_a_long_random_string
NEXTAUTH_URL=http://100.91.82.34:3002

# Storage (Using your existing MinIO)
STORAGE_S3_ENDPOINT=http://100.91.82.34:9200
STORAGE_S3_REGION=us-east-1
STORAGE_S3_ACCESS_KEY=minioadmin
STORAGE_S3_SECRET_KEY=minioadmin123
STORAGE_S3_BUCKET=linkwarden

# Disable registration if you want it private
NEXT_PUBLIC_REGISTRATION_DISABLED=false
